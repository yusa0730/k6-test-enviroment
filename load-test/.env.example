# load-test 実行用の環境変数（dotenvx で読み込む）
# cp .env.example .env で作成する

# 対象環境のベースURL。HTTPクライアントのテスト用に公式に提供されている一般公開サイトを使う
BASE_URL=https://httpbin.org

# Origin ヘッダー用（通常は BASE_URL と同じ値でよい）
ORIGIN=https://httpbin.org

# SSM Parameter Store に保存されているトークンと同じ値を入れると、GET /headers の
# 認証付きAPIを模したチェックが有効になる（ECS実行時はコンテナがSSMから自動取得するため不要）
LOAD_TEST_TOKEN=

# true にすると「スタブ切り替え」時の軽量エンドポイントを、false にすると
# 重い依存先呼び出しを模した /delay/1 を叩く
STUB_ENABLED=false

# 実行を識別するタグ（S3の結果保存パスに使う）
TEST_RUN_ID=local
